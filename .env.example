# Claudine Telegram Bot Configuration
# Copy this file to .env and fill in your values

# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Allowed Telegram Chat IDs (comma-separated for multiple users)
# Get your ID by messaging @userinfobot on Telegram
# Single user:   TELEGRAM_CHAT_IDS=123456789
# Multiple:      TELEGRAM_CHAT_IDS=123456789,987654321
TELEGRAM_CHAT_IDS=your_chat_id_here

# Anthropic API Key
ANTHROPIC_API_KEY=your_api_key_here

# Working directory for Claude operations (optional, defaults to current directory)
WORKING_DIR=/home/pi/projects

# Jira (Atlassian REST API) — used by the proactive digest in src/digest.ts.
# All three are required for the digest to run; leave blank to disable.
# Generate a token at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_SITE=your-site.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your_token_here

# How often the proactive Jira digest runs, in minutes. Default 30.
# Set lower (e.g. 1) while iterating, raise once you're happy with it.
DIGEST_INTERVAL_MINUTES=30
