{
  "name": "claudine-telegram",
  "version": "3.0.0",
  "description": "A Claude-powered Telegram bot running on Raspberry Pi",
  "type": "module",
  "private": true,
  "main": "src/index.ts",
  "scripts": {
    "start": "tsx --env-file=.env src/index.ts",
    "dev": "tsx watch --env-file=.env src/index.ts",
    "start:old": "tsx index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.3",
    "js-yaml": "^4.1.1",
    "node-telegram-bot-api": "^0.66.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.0",
    "@types/node-telegram-bot-api": "^0.64.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
